    txt.TextWrapped = true
    txt.Font = Enum.Font.SourceSans
    txt.TextSize = 14
    txt.TextXAlignment = Enum.TextXAlignment.Left

    task.defer(function()
        ChatFrame.CanvasPosition = Vector2.new(0, ChatFrame.AbsoluteContentSize.Y)
    end)
end

