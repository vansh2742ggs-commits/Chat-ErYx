Input.Position = UDim2.new(0.03, 0, 0.85, 0)
Input.BackgroundColor3 = WHITE
Input.PlaceholderText = "Type to script users..." 
Input.Text = ""
Instance.new("UICorner", Input)

local Send = Instance.new("TextButton", Main)
Send.Size = UDim2.new(0, 70, 0, 30)
Send.Position = UDim2.new(0.75, 0, 0.85, 0)
Send.Text = "SEND"
Send.BackgroundColor3 = WHITE
Instance.new("UICorner", Send)

local function broadcast()
    if Input.Text ~= "" then
        -- Instead of sending to game chat, we update the shared Value
        SharedEvent.Value = player.Name .. "|||" .. Input.Text
        
        -- Reset value quickly so it can be triggered again by the same person
        task.wait(0.1)
        SharedEvent.Value = ""
        
        Input.Text = ""
    end
end

Send.MouseButton1Click:Connect(broadcast)
Input.FocusLost:Connect(function(e) if e then broadcast() end end)

