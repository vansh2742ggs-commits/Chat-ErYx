-- 3. MESSAGE LOGIC
local msgCount = 0
local function addMessage(sender, text, isSpecialColor)
    msgCount = msgCount + 1
    
    -- Limit to 30 messages
    local currentMsgs = ChatBox:GetChildren()
    local frames = {}
    for _, v in pairs(currentMsgs) do if v:IsA("Frame") then table.insert(frames, v) end end
    
    if #frames >= 30 then
        frames[1]:Destroy()
    end

    local msg = Instance.new("Frame", ChatBox)
    msg.Name = "MessageFrame"
    msg.Size = UDim2.new(1, -10, 0, 0)
    msg.AutomaticSize = Enum.AutomaticSize.Y
    msg.BackgroundColor3 = isSpecialColor or SKY_BLUE
    msg.LayoutOrder = msgCount
    Instance.new("UICorner", msg).CornerRadius = UDim.new(0, 4)

    local txt = Instance.new("TextLabel", msg)
    txt.Size = UDim2.new(1, -10, 1, 0)
    txt.Position = UDim2.new(0, 5, 0, 0)
    txt.BackgroundTransparency = 1
    txt.TextWrapped = true
    txt.TextSize = 12
    txt.Font = Enum.Font.SourceSansBold
    txt.TextColor3 = Color3.new(0,0,0)
    txt.Text = sender .. ": " .. text
    txt.TextXAlignment = Enum.TextXAlignment.Left

    -- Auto Scroll to newest
    task.defer(function()
        ChatBox.CanvasPosition = Vector2.new(0, ChatBox.AbsoluteContentSize.Y)
    end)
end

