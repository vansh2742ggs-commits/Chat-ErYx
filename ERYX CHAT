-- 4. NOTIFICATION TOAST
local function CreatePopup(sender, text, creator)
    local popup = Instance.new("Frame", ScreenGui)
    popup.Size = UDim2.new(0, 300, 0, 45)
    popup.Position = UDim2.new(0.5, -150, -0.2, 0)
    popup.BackgroundColor3 = creator and GOLD or WHITE
    Instance.new("UICorner", popup)
    Instance.new("UIStroke", popup).Color = PURPLE

    local lbl = Instance.new("TextLabel", popup)
    lbl.Size = UDim2.new(1, -20, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.SourceSansBold
    lbl.Text = sender .. ": " .. text
    lbl.TextWrapped = true

    popup:TweenPosition(UDim2.new(0.5, -150, 0.05, 0), "Out", "Back", 0.4, true)
    task.delay(3, function()
        if popup then
            popup:TweenPosition(UDim2.new(0.5, -150, -0.2, 0), "In", "Quad", 0.4, true, function() popup:Destroy() end)
        end
    end)
end

-- 5. ADD MESSAGE TO GUI
local function addMsg(sender, text)
    local creator = isOwner(sender)
    local msgFrame = Instance.new("Frame", ChatBox)
    msgFrame.Size = UDim2.new(1, 0, 0, 0)
    msgFrame.AutomaticSize = Enum.AutomaticSize.Y
    msgFrame.BackgroundColor3 = creator and GOLD or SKY_BLUE
    Instance.new("UICorner", msgFrame)

    local txt = Instance.new("TextLabel", msgFrame)
    txt.Size = UDim2.new(1, -10, 1, 0)
    txt.Position = UDim2.new(0, 5, 0, 0)
    txt.BackgroundTransparency = 1
    txt.Text = (creator and "👑 " or "") .. sender .. ": " .. text
    txt.Font = creator and Enum.Font.SourceSansBold or Enum.Font.SourceSans
    txt.TextWrapped = true
    txt.TextXAlignment = Enum.TextXAlignment.Left

    task.defer(function() ChatBox.CanvasPosition = Vector2.new(0, ChatBox.AbsoluteContentSize.Y) end)
    CreatePopup(sender, text, creator)
end

-- 6. THE "SYNC" SCRIPT LOGIC
-- Listen for when the Shared Value changes (this is the script-to-script connection)
SharedEvent.Changed:Connect(function()
    local data = SharedEvent.Value
    if data ~= "" then
        local split = data:split("|||") -- We use a separator to tell sender apart from msg
        local senderName = split[1]
        local messageText = split[2]
        if senderName and messageText then
            addMsg(senderName, messageText)
        end
    end
end)

