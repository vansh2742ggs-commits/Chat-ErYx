SendBtn.Position = UDim2.new(0.78, 0, 0.86, 0)
SendBtn.Text = "Send"
SendBtn.BackgroundColor3 = WHITE
Instance.new("UICorner", SendBtn)

local function sendMessage()
    local t = Input.Text
    if t ~= "" and t:gsub("%s+", "") ~= "" then
        local say = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents"):FindFirstChild("SayMessageRequest")
        if say then say:FireServer(t, "All") end
        Input.Text = ""
    end
end

SendBtn.MouseButton1Click:Connect(sendMessage)
Input.FocusLost:Connect(function(enter) if enter then sendMessage() end end)

-- UI TOGGLES / DRAG
Toggle.MouseButton1Click:Connect(function() Main.Visible = not Main.Visible end)
local dragging, dragStart, startPos
Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true dragStart = input.Position startPos = Main.Position end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
