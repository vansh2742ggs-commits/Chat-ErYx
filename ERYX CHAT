-- 2. PRIVATE COMMUNICATION SETUP (The "Bridge")
-- This creates a folder in ReplicatedStorage that only script users interact with
local BridgeFolder = ReplicatedStorage:FindFirstChild("ErYx_Private_Bridge")
if not BridgeFolder then
    BridgeFolder = Instance.new("Folder", ReplicatedStorage)
    BridgeFolder.Name = "ErYx_Private_Bridge"
end

local SharedEvent = BridgeFolder:FindFirstChild("GlobalMsg")
if not SharedEvent then
    -- We use a StringValue as a 'Pseudo-Remote' for script-to-script talk
    SharedEvent = Instance.new("StringValue", BridgeFolder)
    SharedEvent.Name = "GlobalMsg"
end

