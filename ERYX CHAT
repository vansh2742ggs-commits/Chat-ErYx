-- 3. NOTIFICATION POPUP SYSTEM
local function CreatePopup(sender, text, isOwnerMsg)
    local popup = Instance.new("Frame", ScreenGui)
    popup.Size = UDim2.new(0, 320, 0, 45)
    popup.Position = UDim2.new(0.5, -160, -0.15, 0) 
    
    -- Change color if Owner
    popup.BackgroundColor3 = isOwnerMsg and GOLD or LAVENDER_WHITE
    Instance.new("UICorner", popup)
    
    local stroke = Instance.new("UIStroke", popup)
    stroke.Color = isOwnerMsg and Color3.fromRGB(255, 100, 0) or PURPLE
    stroke.Thickness = isOwnerMsg and 2 or 1

    local lbl = Instance.new("TextLabel", popup)
    lbl.Size = UDim2.new(1, -20, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.SourceSansBold
    lbl.TextSize = 13
    lbl.TextColor3 = Color3.new(0,0,0)
    lbl.Text = (isOwnerMsg and "👑 " or "") .. sender .. ": " .. text
    lbl.TextWrapped = true

    -- Animation
    popup:TweenPosition(UDim2.new(0.5, -160, 0.03, 0), "Out", "Back", 0.5, true)
    task.delay(4, function()
        if popup then
            popup:TweenPosition(UDim2.new(0.5, -160, -0.15, 0), "In", "Quad", 0.5, true, function()
                popup:Destroy()
            end)
        end
    end)
end

-- 4. MESSAGE HANDLING
local msgCount = 0
local function addMessage(sender, text)
    msgCount = msgCount + 1
    local ownerStatus = isOwner(sender)
    
    -- Cleanup old messages
    local current = ChatBox:GetChildren()
    local frames = {}
    for _, v in pairs(current) do if v:IsA("Frame") then table.insert(frames, v) end end
    if #frames >= 30 then frames[1]:Destroy() end

    local msg = Instance.new("Frame", ChatBox)
    msg.Size = UDim2.new(1, -10, 0, 0)
    msg.AutomaticSize = Enum.AutomaticSize.Y
    msg.BackgroundColor3 = ownerStatus and GOLD or SKY_BLUE
    Instance.new("UICorner", msg).CornerRadius = UDim.new(0, 4)

    local txt = Instance.new("TextLabel", msg)
    txt.Size = UDim2.new(1, -10, 1, 0)
    txt.Position = UDim2.new(0, 5, 0, 0)
    txt.BackgroundTransparency = 1
    txt.TextWrapped = true
    txt.TextSize = 11
    txt.Font = ownerStatus and Enum.Font.SourceSansBold or Enum.Font.SourceSans
    txt.Text = (ownerStatus and "[OWNER] " or "") .. sender .. ": " .. text
    txt.TextXAlignment = Enum.TextXAlignment.Left

    task.defer(function()
        ChatBox.CanvasPosition = Vector2.new(0, ChatBox.AbsoluteContentSize.Y)
    end)
    
    CreatePopup(sender, text, ownerStatus)
end

-- 5. SERVER CONNECTION
local function connectPlayer(p)
    p.Chatted:Connect(function(msg) addMessage(p.Name, msg) end)
end
for _, p in pairs(Players:GetPlayers()) do connectPlayer(p) end
Players.PlayerAdded:Connect(connectPlayer)

