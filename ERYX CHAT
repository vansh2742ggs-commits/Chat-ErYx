-- --- LOGIC ---

local function AddMsg(user, msg, isSys)
    local msgCount = #ChatFrame:GetChildren() - 1
    if msgCount >= 30 then
        ChatFrame:GetChildren()[2]:Destroy() -- Keep it under 30
    end

    local bubble = Instance.new("Frame", ChatFrame)
    bubble.Size = UDim2.new(1, 0, 0, 0)
    bubble.AutomaticSize = Enum.AutomaticSize.Y
    bubble.BackgroundColor3 = Color3.fromRGB(60, 60, 60) -- Gray
    local bCorner = Instance.new("UICorner", bubble)
    bCorner.CornerRadius = UDim.new(0, 8)

    local txt = Instance.new("TextLabel", bubble)
    txt.Size = UDim2.new(1, -10, 1, 0)
    txt.Position = UDim2.new(0, 5, 0, 0)
    txt.BackgroundTransparency = 1
    txt.TextColor3 = Color3.fromRGB(255, 255, 255)
    txt.Text = isSys and msg or user .. ": " .. msg
    txt.TextWrapped = true
    txt.Font = Enum.Font.SourceSans
    txt.TextSize = 14
    txt.TextXAlignment = Enum.TextXAlignment.Left

    ChatFrame.CanvasPosition = Vector2.new(0, ChatFrame.AbsoluteContentSize.Y)
end

-- Function to broadcast
local function broadcast(text, system)
    local tag = system and "ERYX_SYS" or "ERYX_MSG"
    local encoded = tag .. "|||" .. player.Name .. "|||" .. text
    
    -- This fires the game's remote so others see it
    if SyncRemote then
        SyncRemote:FireServer(encoded)
    end
    -- Also add to self
    AddMsg(player.Name, text, system)
end

-- Listener for other script users
-- We "Hook" the remote to listen for incoming ErYx messages
if SyncRemote then
    SyncRemote.OnClientEvent:Connect(function(data)
        if typeof(data) == "string" and data:find("ERYX_") then
            local parts = data:split("|||")
            if parts[1] == "ERYX_MSG" then
                AddMsg(parts[2], parts[3], false)
            elseif parts[1] == "ERYX_SYS" then
                AddMsg(parts[2], parts[3], true)
            end
        end
    end)
end

